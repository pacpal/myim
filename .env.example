# ============================================================
# Environment variables for docker-compose deployment.
# Copy this file to `.env` and adjust values as needed:
#   cp .env.example .env
# Then run:  docker compose up -d --build
# ============================================================

# ---- Backend service ----
# Port exposed on the host to access the IM web app
APP_PORT=8080

# ---- Database ----
# Port exposed on the host (container internal port is always 3306)
DB_PORT=3307
DB_USER=root
DB_PASSWORD=root
DB_NAME=im_system

# ---- Database connection resilience (optional) ----
# Number of retry attempts before the app gives up connecting to MySQL
DB_MAX_RETRIES=30
# Interval between retries (Go duration format: 2s, 500ms, etc.)
DB_RETRY_INTERVAL=2s
